---
import BaseLayout from "../layouts/BaseLayout.astro";

const items = [
  "Biology olympiad preparation.",
  "Computational biology and bioinformatics foundations.",
  "AIVC Learning Notes.",
  "EvoPrior-AIVC."
];
---
<BaseLayout title="Now | Cheng Bai" description="Current work and study items.">
  <section class="paper px-6 py-8 md:px-10">
    <h1 class="font-serif text-4xl tracking-normal md:text-6xl">Now</h1>
    <ul class="mt-6 space-y-4 text-sm leading-7 text-ink-700 dark:text-ink-200">
      {items.map((item) => <li class="border-b border-ink-200 pb-4 dark:border-white/10">{item}</li>)}
    </ul>
  </section>
</BaseLayout>
