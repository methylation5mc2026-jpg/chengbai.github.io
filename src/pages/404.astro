---
import BaseLayout from "../layouts/BaseLayout.astro";

const routes = [
  { href: "/start-here", title: "从这里开始", text: "如果你不确定该读什么，从新读者路径重新进入。" },
  { href: "/books", title: "进入书架", text: "查看正在写的四本书和已有章节。" },
  { href: "/knowledge-map", title: "知识地图", text: "按长期主线寻找相关书籍、专题和标签。" },
  { href: "/search", title: "搜索全站", text: "直接搜索 AIVC、AI4Bio、生信、商业等关键词。" }
];
---
<BaseLayout title="404 | 页面未找到" description="页面未找到，可以从搜索、书架或知识地图继续浏览。">
  <div class="space-y-10">
    <section class="border-b border-ink-200 pb-10 dark:border-white/10">
      <p class="eyebrow">404</p>
      <h1 class="mt-4 max-w-4xl font-serif text-5xl leading-tight tracking-normal md:text-7xl">这页暂时不存在。</h1>
      <p class="mt-6 max-w-3xl text-base leading-8 text-ink-600 dark:text-ink-300">
        可能是链接还没写完，也可能是旧路径已经移动。别急，知识库还在，我们可以从下面几个入口继续。
      </p>
    </section>

    <section class="grid gap-4 md:grid-cols-2">
      {routes.map((item, index) => (
        <a href={item.href} class="route-card group">
          <p class="font-mono text-xs text-ink-500 dark:text-ink-400">{String(index + 1).padStart(2, "0")}</p>
          <h2 class="mt-3 font-serif text-3xl tracking-normal">{item.title}</h2>
          <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">{item.text}</p>
          <span class="mt-5 inline-block font-mono text-xs uppercase tracking-[0.18em] text-accent-600 transition group-hover:translate-x-1 dark:text-accent-400">Go →</span>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>
