---
import { siteConfig } from "../site.config";

const year = new Date().getFullYear();
---
<footer class="mt-16 border-t border-ink-200/80 py-12 dark:border-white/10">
  <div class="container-shell grid gap-10 text-sm text-ink-500 md:grid-cols-[1.3fr_0.7fr_0.7fr_0.7fr] dark:text-ink-400">
    <div>
      <p class="font-serif text-2xl text-ink-900 dark:text-white">{siteConfig.name}</p>
      <p class="mt-3 max-w-md leading-7">
        {siteConfig.identity}
      </p>
      <p class="mt-6">© {year} Cheng Bai</p>
    </div>
    <div>
      <h2 class="font-mono text-xs uppercase tracking-[0.18em] text-ink-900 dark:text-white">Read</h2>
      <div class="mt-4 grid gap-2">
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/books/aivc-whitepaper/">AIVC Learning Notes</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/articles">Writing</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/knowledge-map">Notes</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/rss.xml">RSS</a>
      </div>
    </div>
    <div>
      <h2 class="font-mono text-xs uppercase tracking-[0.18em] text-ink-900 dark:text-white">Navigate</h2>
      <div class="mt-4 grid gap-2">
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/#about">About</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/#projects">Projects</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/#honors">Honors</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/#contact">Contact</a>
      </div>
    </div>
    <div>
      <h2 class="font-mono text-xs uppercase tracking-[0.18em] text-ink-900 dark:text-white">Contact</h2>
      <p class="mt-4 leading-7">{siteConfig.contactEmail}</p>
      <a class="mt-3 inline-block hover:text-accent-600 dark:hover:text-accent-400" href="https://github.com/methylation5mc2026-jpg">GitHub</a>
    </div>
  </div>
</footer>
