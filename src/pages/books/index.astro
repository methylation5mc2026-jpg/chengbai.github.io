---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cleanSlug, getBooks } from "../../lib/content";

const books = await getBooks();
---
<BaseLayout title="Books | Zeheng Shen" description="Books and notes.">
  <div class="space-y-10">
    <section class="border-b border-ink-200 pb-10 dark:border-white/10">
      <h1 class="font-serif text-5xl leading-tight tracking-normal md:text-7xl">Books</h1>
    </section>

    <section class="grid gap-5">
      {books.map((book) => (
        <article class="paper p-6">
          <h2 class="font-serif text-4xl tracking-normal">
            <a href={`/books/${cleanSlug(book.id)}/`} class="transition hover:text-accent-600 dark:hover:text-accent-400">{book.data.title}</a>
          </h2>
          <p class="mt-4 max-w-3xl text-sm leading-7 text-ink-600 dark:text-ink-300">{book.data.description}</p>
          <a class="mt-5 inline-block font-mono text-xs uppercase tracking-[0.18em] text-accent-600 dark:text-accent-400" href={`/books/${cleanSlug(book.id)}/`}>Open</a>
        </article>
      ))}
    </section>
  </div>
</BaseLayout>
