---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cleanSlug, formatDate, getDailyEntries, getWordCount } from "../../lib/content";

const entries = await getDailyEntries();
const totalWords = entries.reduce((sum, entry) => sum + getWordCount(entry.body), 0);
const latestEntry = entries[0];
---
<BaseLayout title="日报 | 白城 AI for Biology Knowledge Assets" description="记录每天在思想认知上的突破与成长，凝结为可复用的原则和方法论。">
  <div class="space-y-12">
    <section class="grid gap-8 border-b border-ink-200 pb-10 dark:border-white/10 lg:grid-cols-[minmax(0,1fr)_360px]">
      <div>
        <p class="eyebrow">Daily Principles</p>
        <h1 class="mt-4 max-w-5xl font-serif text-5xl leading-tight tracking-normal md:text-7xl">
          日报不是流水账，<br />而是每天结晶一个可复用原则。
        </h1>
        <p class="mt-6 max-w-3xl text-base leading-8 text-ink-600 dark:text-ink-300">
          这里记录每天在思想认知上的突破与成长。可长可短，甚至可以只有一句话；重点不是“今天发生了什么”，而是把一次经历、一次反省、一次卡点，压缩成日后还能调用的原则和方法论。
        </p>
      </div>

      <aside class="h-fit border-y border-ink-200 py-5 text-sm dark:border-white/10 lg:border-l lg:border-y-0 lg:pl-8">
        <div class="grid gap-4">
          <div class="flex items-start justify-between gap-6 border-b border-ink-200/80 pb-4 dark:border-white/10">
            <span class="text-ink-500 dark:text-ink-400">定位</span>
            <span class="text-right">成长锚点 / 原则库 / 方法论</span>
          </div>
          <div class="flex items-start justify-between gap-6 border-b border-ink-200/80 pb-4 dark:border-white/10">
            <span class="text-ink-500 dark:text-ink-400">记录数</span>
            <span>{entries.length} 条</span>
          </div>
          <div class="flex items-start justify-between gap-6 border-b border-ink-200/80 pb-4 dark:border-white/10">
            <span class="text-ink-500 dark:text-ink-400">累计字数</span>
            <span>{totalWords.toLocaleString("zh-CN")}+</span>
          </div>
          <div class="flex items-start justify-between gap-6">
            <span class="text-ink-500 dark:text-ink-400">最近更新</span>
            <span>{latestEntry ? formatDate(latestEntry.data.pubDate) : "暂无"}</span>
          </div>
        </div>
      </aside>
    </section>

    <section class="grid gap-4">
      {entries.map((entry, index) => (
        <a href={`/daily/${cleanSlug(entry.id)}/`} class="group grid gap-5 border-b border-ink-200 py-7 transition hover:border-accent-500 dark:border-white/10 lg:grid-cols-[120px_minmax(0,1fr)_220px]">
          <time class="font-mono text-sm text-ink-500 dark:text-ink-400" datetime={entry.data.pubDate.toISOString()}>
            {formatDate(entry.data.pubDate)}
          </time>
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">Entry {String(entries.length - index).padStart(3, "0")}</p>
            <h2 class="mt-2 font-serif text-3xl tracking-normal transition group-hover:text-accent-600 dark:group-hover:text-accent-400">
              {entry.data.title}
            </h2>
            <p class="mt-3 max-w-3xl text-sm leading-7 text-ink-600 dark:text-ink-300">{entry.data.description}</p>
          </div>
          <div class="flex flex-wrap content-start gap-2 lg:justify-end">
            {entry.data.tags.map((tag) => <span class="tag-chip">#{tag}</span>)}
          </div>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>
