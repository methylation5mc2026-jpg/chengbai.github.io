---
import BaseLayout from "../layouts/BaseLayout.astro";

const checks = [
  {
    title: "Local Health Check",
    command: "npm run ops:health",
    text: "Checks health endpoints, the homepage, book routes, the AIVC book page, search, and security headers."
  },
  {
    title: "Local Persistent Preview",
    command: "npm run preview:keepalive",
    text: "Starts a static preview service and restarts it when needed."
  },
  {
    title: "Startup Preview",
    command: "npm run startup:install",
    text: "Installs the local preview process for the current Windows user."
  },
  {
    title: "Production Build",
    command: "npm run build",
    text: "Generates the static site, RSS, Sitemap, and Pagefind search index."
  }
];

const securityItems = [
  "Content-Security-Policy limits script, style, image, font, and frame sources.",
  "X-Content-Type-Options: nosniff reduces MIME sniffing risk.",
  "X-Frame-Options: DENY and frame-ancestors reduce framing risk.",
  "Referrer-Policy limits cross-site referrer leakage.",
  "Permissions-Policy disables browser permissions that the static site does not need.",
  "_headers supports Cloudflare Pages, and vercel.json supports Vercel."
];
---
<BaseLayout title="Ops | Zeheng Shen" description="Security, operations, health checks, and deployment notes for this static personal site.">
  <div class="space-y-12">
    <section class="grid gap-8 border-b border-ink-200 pb-10 dark:border-white/10 lg:grid-cols-[1fr_0.6fr]">
      <div>
        <p class="eyebrow">Security & Operations</p>
        <h1 class="mt-4 max-w-4xl font-serif text-5xl leading-tight tracking-normal md:text-7xl">Static Site Operations</h1>
      </div>
      <p class="text-sm leading-8 text-ink-600 dark:text-ink-300">
        This site is a static Astro site with a small operational surface: build, preview, cache behavior, security headers, health checks, and deployment consistency.
      </p>
    </section>

    <section class="grid gap-6 md:grid-cols-2">
      {checks.map((item) => (
        <article class="ops-card">
          <h2 class="font-serif text-3xl tracking-normal">{item.title}</h2>
          <code class="mt-4 inline-block rounded bg-ink-100 px-3 py-2 font-mono text-sm dark:bg-white/10">{item.command}</code>
          <p class="mt-4 text-sm leading-7 text-ink-600 dark:text-ink-300">{item.text}</p>
        </article>
      ))}
    </section>

    <section class="grid gap-8 lg:grid-cols-[360px_minmax(0,1fr)]">
      <div>
        <p class="eyebrow">Security Baseline</p>
        <h2 class="mt-3 font-serif text-4xl tracking-normal">Current Security Baseline</h2>
      </div>
      <div class="grid gap-3">
        {securityItems.map((item, index) => (
          <div class="grid gap-4 border-b border-ink-200 pb-4 dark:border-white/10 md:grid-cols-[56px_minmax(0,1fr)]">
            <p class="font-mono text-sm text-ink-500 dark:text-ink-400">{String(index + 1).padStart(2, "0")}</p>
            <p class="text-sm leading-7 text-ink-600 dark:text-ink-300">{item}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
