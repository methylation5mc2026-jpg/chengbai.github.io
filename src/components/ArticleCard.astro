---
import { cleanSlug, formatDate } from "../lib/content";

interface Props {
  article: any;
}

const { article } = Astro.props;
---
<article class="rounded-3xl border border-ink-200/80 bg-white p-6 transition hover:-translate-y-0.5 hover:border-accent-500 dark:border-white/10 dark:bg-white/5">
  <div class="mb-3 flex flex-wrap items-center gap-3 text-sm text-ink-500 dark:text-ink-400">
    <time datetime={article.data.pubDate.toISOString()}>{formatDate(article.data.pubDate)}</time>
    {article.data.collection && <span>{article.data.collection}</span>}
  </div>
  <h3 class="font-serif text-2xl tracking-tight">
    <a href={`/articles/${cleanSlug(article.id)}/`} class="hover:text-accent-600 dark:hover:text-accent-400">{article.data.title}</a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">{article.data.description}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {article.data.tags.map((tag: string) => <span class="tag-chip">#{tag}</span>)}
  </div>
</article>
