---
import BaseLayout from "../layouts/BaseLayout.astro";

const paths = [
  {
    title: "给会务老师或导师",
    href: "/articles/aivc-week-learning-brief/",
    text: "先读这篇 3 分钟学习简报：它解释我为什么想参加 AIVC Week，以及我目前知道什么、还缺什么。"
  },
  {
    title: "想看长期方向",
    href: "/books/aivc-whitepaper/",
    text: "进入《AIVC白皮书》，看我如何把 AI Virtual Cell、蛋白质组学和科研问题组织成长期学习项目。"
  },
  {
    title: "想看方法意识",
    href: "/articles/bioinformatics-pipeline-thinking/",
    text: "这篇文章展示我如何用问题、数据、方法三层视角理解生物信息学，而不是只记软件命令。"
  },
  {
    title: "想看完整知识资产",
    href: "/knowledge-map",
    text: "进入知识地图，按 AIVC、AI4Bio、生信、竞赛和论文阅读等主题浏览。"
  }
];
---
<BaseLayout title="Start Here | 白城 AI for Biology Knowledge Assets" description="第一次来到白城个人网站，可以从这里选择最适合的阅读路径。">
  <div class="space-y-10">
    <section class="border-b border-ink-200 pb-10 dark:border-white/10">
      <p class="eyebrow">Start Here</p>
      <h1 class="mt-4 max-w-4xl font-serif text-5xl leading-tight tracking-normal md:text-7xl">第一次来，请按你的目的选择入口。</h1>
      <p class="mt-6 max-w-3xl text-base leading-8 text-ink-600 dark:text-ink-300">
        这个网站不是时间线博客，而是一个用于展示成长速度、知识资产和 AI for Biology 长期方向的公开档案。
      </p>
    </section>

    <section class="grid gap-6 md:grid-cols-2">
      {paths.map((item, index) => (
        <a href={item.href} class="group border-y border-ink-200 py-6 transition hover:border-accent-500 hover:text-accent-600 dark:border-white/10 dark:hover:text-accent-400">
          <p class="font-mono text-xs text-ink-500 dark:text-ink-400">{String(index + 1).padStart(2, "0")}</p>
          <h2 class="mt-3 font-serif text-3xl tracking-normal">{item.title}</h2>
          <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">{item.text}</p>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>
