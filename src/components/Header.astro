---
import ThemeToggle from "./ThemeToggle.astro";
import { siteConfig } from "../site.config";

const links = siteConfig.nav;
---
<header class="sticky top-0 z-30 border-b border-ink-200/80 bg-ink-50/90 backdrop-blur dark:border-white/10 dark:bg-ink-900/85">
  <div class="container-shell flex min-h-16 flex-wrap items-center justify-between gap-x-6 gap-y-3 py-3">
    <a href="/" class="flex items-baseline gap-2 font-serif text-xl tracking-normal">
      <span>{siteConfig.name}</span>
      <span class="font-mono text-xs uppercase text-ink-500 dark:text-ink-400">Personal Homepage</span>
    </a>
    <nav class="order-3 flex w-full flex-wrap gap-x-4 gap-y-2 border-t border-ink-200/70 pt-3 xl:order-2 xl:w-auto xl:border-0 xl:pt-0" aria-label="Primary navigation">
      {links.map((link) => (
        <a class="nav-link whitespace-nowrap" href={link.href}>{link.label}</a>
      ))}
    </nav>
    <div class="order-2 xl:order-3">
      <ThemeToggle />
    </div>
  </div>
</header>
