---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site.config";

const evidence = [
  {
    title: "Biology Olympiad Training",
    text: "Two consecutive Shanghai provincial first prizes in the National Biology Olympiad / CHSBO, with training across biochemistry, cell biology, genetics, ecology, and experimental reasoning."
  },
  {
    title: "AI for Science Competition",
    text: "Team Lead, SAIS AI4S Agent CNS Challenge 2026; ranked 34th nationally and advanced to the semifinal / second round."
  },
  {
    title: "Computational Biology Self-study",
    text: "Currently building foundations in bioinformatics, computational biology, machine learning, deep learning, and AI for Biology through reading and project-based learning."
  }
];

const stacks = [
  "Biochemistry",
  "Cell biology",
  "Molecular biology",
  "Bioinformatics basics",
  "Python / R / pandas / numpy",
  "Linux / Git / conda",
  "sklearn / PyTorch basics",
  "PubMed / NCBI / PDB",
  "Paper reading",
  "Project documentation"
];

const boundaries = [
  "I am still at an early learning stage and do not present study notes as research results.",
  "Competition and project records show preparation and execution, but they are not a substitute for mature research experience.",
  "The materials kept here are meant to be inspected: what I have read, what I have built, what the evidence supports, and what still needs work."
];
---
<BaseLayout title="About | Cheng Bai" description="About Cheng Bai: biology olympiad training, AI for Biology interests, projects, skills, and current boundaries.">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
    <section class="space-y-8">
      <div class="paper px-6 py-8 md:px-10">
        <p class="eyebrow mb-3">About</p>
        <h1 class="font-serif text-4xl tracking-normal md:text-6xl">About Cheng Bai</h1>
        <div class="mt-5 max-w-3xl space-y-4 text-base leading-8 text-ink-600 dark:text-ink-300">
          <p>
            I am a high school student in Shanghai with sustained training in biology competitions. My current interest is AI for Biology, especially computational biology, single-cell and multi-omics data, proteomics, and AI Virtual Cell.
          </p>
          <p>
            This site is a compact public profile for teachers, mentors, and peers who want to inspect my preparation directly. It collects selected projects, reading notes, original writing, and records of what I am currently learning.
          </p>
          <p>
            I try to describe my work with clear evidence and limitations. The goal is not to sound finished, but to make my learning path easier to evaluate.
          </p>
        </div>
      </div>

      <div class="paper px-6 py-8 md:px-10">
        <p class="eyebrow mb-3">Evidence</p>
        <h2 class="font-serif text-3xl">Materials That Can Be Checked</h2>
        <div class="mt-6 grid gap-5">
          {evidence.map((item, index) => (
            <article class="grid gap-4 border-b border-ink-200 pb-5 last:border-b-0 last:pb-0 dark:border-white/10 md:grid-cols-[72px_minmax(0,1fr)]">
              <p class="font-mono text-sm text-ink-500 dark:text-ink-400">{String(index + 1).padStart(2, "0")}</p>
              <div>
                <h3 class="font-serif text-2xl">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-ink-600 dark:text-ink-300">{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="paper px-6 py-8 md:px-10">
        <p class="eyebrow mb-3">Boundary</p>
        <h2 class="font-serif text-3xl">How I Keep the Claims Narrow</h2>
        <div class="mt-5 grid gap-4">
          {boundaries.map((item) => (
            <p class="border-b border-ink-200 pb-4 text-sm leading-7 text-ink-600 last:border-b-0 last:pb-0 dark:border-white/10 dark:text-ink-300">
              {item}
            </p>
          ))}
        </div>
      </div>
    </section>

    <aside class="space-y-6">
      <div class="paper p-6">
        <h2 class="font-serif text-2xl">Skills and Tools</h2>
        <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">
          Listed as foundations I am familiar with or currently learning, not as expert-level claims.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          {stacks.map((item) => <span class="focus-pill">{item}</span>)}
        </div>
      </div>
      <div class="paper p-6">
        <h2 class="font-serif text-2xl">Recommended First Reads</h2>
        <div class="mt-4 grid gap-3 text-sm leading-7 text-ink-600 dark:text-ink-300">
          <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/books/aivc-whitepaper/">AIVC Learning Notes</a>
          <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/articles/">Writing archive</a>
          <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/knowledge-map">Knowledge map</a>
        </div>
      </div>
      <div class="paper p-6">
        <h2 class="font-serif text-2xl">Contact</h2>
        <div class="mt-4 grid gap-3 text-sm leading-7 text-ink-600 dark:text-ink-300">
          <a class="hover:text-accent-600 dark:hover:text-accent-400" href={`mailto:${siteConfig.contactEmail}`}>{siteConfig.contactEmail}</a>
          <a class="hover:text-accent-600 dark:hover:text-accent-400" href="https://github.com/methylation5mc2026-jpg" target="_blank" rel="noreferrer">GitHub overview</a>
          <a class="hover:text-accent-600 dark:hover:text-accent-400" href={siteConfig.cvHref} download>Download CV</a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
