---
import readingTime from "reading-time";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PrevNextNav from "../../components/PrevNextNav.astro";
import TOC from "../../components/TOC.astro";
import { cleanSlug, formatDate, getDailyEntries, tagToSlug } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getDailyEntries();
  return entries.map((entry) => ({
    params: { slug: cleanSlug(entry.id) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const entries = await getDailyEntries();
const currentIndex = entries.findIndex((item) => item.id === entry.id);
const prevEntry = entries[currentIndex + 1];
const nextEntry = entries[currentIndex - 1];
const stats = readingTime(entry.body);
const { Content, headings } = await entry.render();
---
<BaseLayout title={`${entry.data.title} | 日报`} description={entry.data.description}>
  <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_280px]">
    <article class="reader-body space-y-8">
      <header class="border-y border-ink-200 py-8 dark:border-white/10 md:py-10">
        <div class="space-y-4">
          <p class="eyebrow">Daily Principles</p>
          <div class="flex flex-wrap gap-3 text-sm text-ink-500 dark:text-ink-400">
            <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate)}</time>
            <span>{Math.max(1, Math.round(stats.minutes))} 分钟阅读</span>
            {entry.data.updatedDate && <span>更新于 {formatDate(entry.data.updatedDate)}</span>}
          </div>
          <h1 class="max-w-4xl font-serif text-4xl leading-tight tracking-normal md:text-6xl">{entry.data.title}</h1>
          <p class="max-w-3xl text-base leading-8 text-ink-600 dark:text-ink-300">{entry.data.description}</p>
          <div class="flex flex-wrap gap-2">
            {entry.data.tags.map((tag: string) => (
              <a class="tag-chip transition hover:border-accent-500 hover:text-accent-600 dark:hover:text-accent-400" href={`/tags/${tagToSlug(tag)}/`}>#{tag}</a>
            ))}
          </div>
        </div>
      </header>

      <section class="paper px-6 py-8 md:px-10 md:py-10">
        <div class="prose-shell">
          <Content />
        </div>
      </section>

      <PrevNextNav
        prev={prevEntry ? { href: `/daily/${cleanSlug(prevEntry.id)}/`, title: prevEntry.data.title } : null}
        next={nextEntry ? { href: `/daily/${cleanSlug(nextEntry.id)}/`, title: nextEntry.data.title } : null}
      />
    </article>

    <aside class="space-y-6 lg:sticky lg:top-24 lg:h-fit">
      <TOC headings={headings} />
      <a href="/daily" class="asset-button w-full justify-center">返回日报</a>
    </aside>
  </div>
</BaseLayout>
