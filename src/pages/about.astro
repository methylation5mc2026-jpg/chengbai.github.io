---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site.config";

const links = [
  { label: "Email", href: `mailto:${siteConfig.contactEmail}`, text: siteConfig.contactEmail },
  { label: "GitHub", href: "https://github.com/methylation5mc2026-jpg", text: "methylation5mc2026-jpg" },
  { label: "CV", href: siteConfig.cvHref, text: "Download" }
];
---
<BaseLayout title="About | Cheng Bai" description="About Cheng Bai.">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
    <section class="paper px-6 py-8 md:px-10">
      <h1 class="font-serif text-4xl tracking-normal md:text-6xl">About</h1>
      <div class="mt-6 max-w-3xl space-y-4 text-base leading-8 text-ink-600 dark:text-ink-300">
        <p>
          I am a high school student in Shanghai with a background in biology olympiad training. My interests include AI for Biology, computational biology, proteomics, bioinformatics, and AI Virtual Cell.
        </p>
        <p>This site collects my essays, notes, projects, and records.</p>
      </div>
    </section>

    <aside class="paper h-fit p-6">
      <h2 class="font-serif text-2xl">Links</h2>
      <div class="mt-4 grid gap-3 text-sm leading-7 text-ink-600 dark:text-ink-300">
        {links.map((item) => (
          <a class="hover:text-accent-600 dark:hover:text-accent-400" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
            {item.label}: {item.text}
          </a>
        ))}
      </div>
    </aside>
  </div>
</BaseLayout>
