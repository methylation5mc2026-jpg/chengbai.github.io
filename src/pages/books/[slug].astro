---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cleanSlug, getBookChapters, getBooks, getChapterDisplayNumber, getLeafSlug } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getBooks();
  return entries.map((entry) => ({
    params: { slug: cleanSlug(entry.id) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const slug = cleanSlug(entry.id);
const chapters = await getBookChapters(entry.id);
---
<BaseLayout title={`${entry.data.title} | Books`} description={entry.data.description}>
  <div class="space-y-10">
    <section class="border-b border-ink-200 pb-10 dark:border-white/10">
      <h1 class="max-w-4xl font-serif text-5xl leading-tight tracking-normal md:text-7xl">{entry.data.title}</h1>
      <p class="mt-6 max-w-3xl text-base leading-8 text-ink-600 dark:text-ink-300">{entry.data.description}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/books/" class="asset-button">Books</a>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-3xl tracking-normal">Contents</h2>
      <div class="mt-6 grid gap-3">
        {chapters.map((chapter, index) => (
          <a href={`/books/${slug}/${getLeafSlug(chapter.id)}/`} class="grid gap-3 border-b border-ink-200 pb-4 transition hover:text-accent-600 dark:border-white/10 dark:hover:text-accent-400 md:grid-cols-[56px_minmax(0,1fr)]">
            <span class="font-mono text-sm text-ink-500 dark:text-ink-400">{getChapterDisplayNumber(chapter, index)}</span>
            <span class="font-serif text-xl">{chapter.data.title}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
