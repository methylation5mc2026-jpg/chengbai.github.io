---
import BaseLayout from "../layouts/BaseLayout.astro";

const paths = [
  {
    title: "About",
    href: "/about/",
    text: "Background, learning direction, and contact information."
  },
  {
    title: "Books",
    href: "/books/aivc-whitepaper/",
    text: "Long-form AIVC notes."
  },
  {
    title: "Articles",
    href: "/articles/",
    text: "Articles and records."
  },
  {
    title: "Projects",
    href: "/#projects",
    text: "Projects, competitions, and training records."
  }
];
---
<BaseLayout title="Guide | Zeheng Shen" description="Main sections of Zeheng Shen's personal homepage.">
  <div class="space-y-10">
    <section class="border-b border-ink-200 pb-10 dark:border-white/10">
      <p class="eyebrow">Guide</p>
      <h1 class="mt-4 max-w-4xl font-serif text-5xl leading-tight tracking-normal md:text-7xl">Entry points</h1>
      <p class="mt-6 max-w-3xl text-base leading-8 text-ink-600 dark:text-ink-300">
        A compact route list for the main sections of this site.
      </p>
    </section>

    <section class="grid gap-6 md:grid-cols-2">
      {paths.map((item, index) => (
        <a href={item.href} class="group border-y border-ink-200 py-6 transition hover:border-accent-500 hover:text-accent-600 dark:border-white/10 dark:hover:text-accent-400">
          <p class="font-mono text-xs text-ink-500 dark:text-ink-400">{String(index + 1).padStart(2, "0")}</p>
          <h2 class="mt-3 font-serif text-3xl tracking-normal">{item.title}</h2>
          <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">{item.text}</p>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>
