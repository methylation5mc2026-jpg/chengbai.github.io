---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Daily Notes | Cheng Bai" description="Daily notes are not part of the current public profile.">
  <section class="paper px-6 py-8 md:px-10 md:py-10">
    <p class="eyebrow mb-3">Daily Notes</p>
    <h1 class="font-serif text-4xl tracking-normal md:text-6xl">This archive is currently hidden.</h1>
    <p class="mt-5 max-w-3xl text-base leading-8 text-ink-600 dark:text-ink-300">
      Daily notes are not part of the current public profile. Please use the homepage, AIVC Learning Notes, writing archive, or knowledge map.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href="/" class="asset-button">Homepage</a>
      <a href="/books/aivc-whitepaper/" class="asset-button">AIVC Learning Notes</a>
      <a href="/articles/" class="asset-button">Writing</a>
      <a href="/knowledge-map/" class="asset-button">Knowledge Map</a>
    </div>
  </section>
</BaseLayout>
