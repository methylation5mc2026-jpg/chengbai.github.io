---
import { siteConfig } from "../site.config";

const year = new Date().getFullYear();
---
<footer class="mt-16 border-t border-ink-200/80 py-10 dark:border-white/10">
  <div class="container-shell flex flex-col gap-5 text-sm text-ink-500 md:flex-row md:items-center md:justify-between dark:text-ink-400">
    <div>
      <p class="font-serif text-2xl text-ink-900 dark:text-white">{siteConfig.name}</p>
      <p class="mt-2 max-w-md leading-7">{siteConfig.identity}</p>
      <p class="mt-4">(c) {year} Zeheng Shen</p>
    </div>
    <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Footer navigation">
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/#about">About</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/#news">News</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/#education">Education</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/#honors">Honors</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/#projects">Projects</a>
        <a class="hover:text-accent-600 dark:hover:text-accent-400" href="/rss.xml">RSS</a>
    </nav>
  </div>
</footer>
