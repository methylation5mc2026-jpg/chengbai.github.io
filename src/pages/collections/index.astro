---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { cleanSlug, getTopicCollections } from "../../lib/content";

const collections = await getTopicCollections();
---
<BaseLayout title="Topics | Zeheng Shen" description="Topics.">
  <div class="space-y-10">
    <section class="border-b border-ink-200 pb-10 dark:border-white/10">
      <h1 class="font-serif text-5xl leading-tight tracking-normal md:text-7xl">Topics</h1>
    </section>

    <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {collections.map((item) => (
        <a href={`/collections/${cleanSlug(item.id)}/`} class="paper flex min-h-44 flex-col justify-between p-6 transition hover:border-accent-500">
          <h2 class="font-serif text-3xl">{item.data.title}</h2>
          <span class="font-mono text-xs uppercase tracking-[0.18em] text-accent-600 dark:text-accent-400">Open</span>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>
