<div class="reader-controls flex items-center gap-2" aria-label="阅读设置">
  <button class="reader-control-button" type="button" data-reader-font="minus" aria-label="减小字号">A-</button>
  <button class="reader-control-button" type="button" data-reader-font="plus" aria-label="增大字号">A+</button>
  <button class="reader-control-button" type="button" data-reader-width="narrow" aria-label="窄版阅读">窄</button>
  <button class="reader-control-button" type="button" data-reader-width="wide" aria-label="宽版阅读">宽</button>
</div>

<script is:inline>
  (() => {
  const shell = document.querySelector("[data-reader-shell]");
  if (!shell || shell.dataset.readerReady === "true") return;
  shell.dataset.readerReady = "true";

  const scrollBar = document.querySelector("[data-reader-scrollbar]");
  const prevHref = shell.dataset.prevChapter;
  const nextHref = shell.dataset.nextChapter;

  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
  const applyReaderState = () => {
    if (!shell) return;
    const font = localStorage.getItem("reader-font") || "1.08";
    const width = localStorage.getItem("reader-width") || "74";
    shell.style.setProperty("--reader-size", `${font}rem`);
    shell.style.setProperty("--reader-width", `${width}ch`);
  };

  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const fontButton = target.closest("[data-reader-font]");
    if (fontButton instanceof HTMLElement) {
      const current = Number(localStorage.getItem("reader-font") || "1.08");
      const delta = fontButton.dataset.readerFont === "plus" ? 0.04 : -0.04;
      localStorage.setItem("reader-font", String(clamp(current + delta, 0.96, 1.28).toFixed(2)));
      applyReaderState();
      return;
    }

    const widthButton = target.closest("[data-reader-width]");
    if (widthButton instanceof HTMLElement) {
      localStorage.setItem("reader-width", widthButton.dataset.readerWidth === "wide" ? "86" : "64");
      applyReaderState();
    }
  });

  const updateScrollBar = () => {
    if (!scrollBar) return;
    const max = document.documentElement.scrollHeight - window.innerHeight;
    const value = max > 0 ? (window.scrollY / max) * 100 : 0;
    scrollBar.style.width = `${Math.min(100, Math.max(0, value))}%`;
  };

  document.addEventListener("keydown", (event) => {
    if (event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    if (event.key === "ArrowLeft" && prevHref) window.location.href = prevHref;
    if (event.key === "ArrowRight" && nextHref) window.location.href = nextHref;
  });

  applyReaderState();
  updateScrollBar();
  window.addEventListener("scroll", updateScrollBar, { passive: true });
  window.addEventListener("resize", updateScrollBar);
  })();
</script>
