---
import BaseLayout from "../layouts/BaseLayout.astro";

const checks = [
  {
    title: "本地健康检查",
    command: "npm run ops:health",
    text: "检查 /healthz、首页、书架、AIVC 书籍页和搜索页是否可访问，并确认关键安全响应头存在。"
  },
  {
    title: "本地常驻预览",
    command: "npm run preview:keepalive",
    text: "启动静态服务并持续探活，服务异常时自动重启。"
  },
  {
    title: "开机自启动",
    command: "npm run startup:install",
    text: "把本地守护进程安装到当前 Windows 用户 Startup 目录，登录后自动恢复网站预览。"
  },
  {
    title: "生产构建",
    command: "npm run build",
    text: "生成静态站点、RSS、Sitemap 和 Pagefind 搜索索引。"
  }
];

const securityItems = [
  "Content-Security-Policy 限制脚本、样式、图片、字体和 frame 嵌入来源。",
  "X-Content-Type-Options: nosniff 防止浏览器 MIME 嗅探。",
  "X-Frame-Options: DENY 与 frame-ancestors 防止页面被恶意嵌入。",
  "Referrer-Policy 降低跨站跳转时泄漏路径信息的概率。",
  "Permissions-Policy 禁用摄像头、麦克风、地理位置、支付、USB 等不需要的浏览器权限。",
  "_headers 适配 Cloudflare Pages，vercel.json 适配 Vercel。"
];
---
<BaseLayout title="Ops | 白城 Knowledge Assets" description="白城个人知识资产网站的安全、运维、健康检查与部署说明。">
  <div class="space-y-12">
    <section class="grid gap-8 border-b border-ink-200 pb-10 dark:border-white/10 lg:grid-cols-[1fr_0.6fr]">
      <div>
        <p class="eyebrow">Security & Operations</p>
        <h1 class="mt-4 max-w-4xl font-serif text-5xl leading-tight tracking-normal md:text-7xl">让个人网站能长期安全地跑下去。</h1>
      </div>
      <p class="text-sm leading-8 text-ink-600 dark:text-ink-300">
        这个站点是纯静态架构，没有登录、数据库和复杂后端，攻击面本来就小。运维重点是：稳定构建、稳定预览、清晰缓存、基础安全头、可检查的健康状态，以及部署平台的一致配置。
      </p>
    </section>

    <section class="grid gap-6 md:grid-cols-2">
      {checks.map((item) => (
        <article class="ops-card">
          <h2 class="font-serif text-3xl tracking-normal">{item.title}</h2>
          <code class="mt-4 inline-block rounded bg-ink-100 px-3 py-2 font-mono text-sm dark:bg-white/10">{item.command}</code>
          <p class="mt-4 text-sm leading-7 text-ink-600 dark:text-ink-300">{item.text}</p>
        </article>
      ))}
    </section>

    <section class="grid gap-8 lg:grid-cols-[360px_minmax(0,1fr)]">
      <div>
        <p class="eyebrow">Security Baseline</p>
        <h2 class="mt-3 font-serif text-4xl tracking-normal">当前安全基线</h2>
      </div>
      <div class="grid gap-3">
        {securityItems.map((item, index) => (
          <div class="grid gap-4 border-b border-ink-200 pb-4 dark:border-white/10 md:grid-cols-[56px_minmax(0,1fr)]">
            <p class="font-mono text-sm text-ink-500 dark:text-ink-400">{String(index + 1).padStart(2, "0")}</p>
            <p class="text-sm leading-7 text-ink-600 dark:text-ink-300">{item}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
