---
import readingTime from "reading-time";
import BaseLayout from "./BaseLayout.astro";
import BookReaderControls from "../components/BookReaderControls.astro";
import { getChapterDisplayNumber, getLeafSlug } from "../lib/content";

interface Props {
  entry: any;
  bookTitle: string;
  chapters: any[];
  prev?: { href: string; title: string } | null;
  next?: { href: string; title: string } | null;
}

const { entry, bookTitle, chapters, prev, next } = Astro.props;
const stats = readingTime(entry.body);
const chapterIndex = chapters.findIndex((chapter) => chapter.id === entry.id);
const currentChapterNumber = getChapterDisplayNumber(entry, chapterIndex);
const lastChapterNumber = getChapterDisplayNumber(chapters[chapters.length - 1] ?? entry, chapters.length - 1);
const progressLabel = `${currentChapterNumber} / ${lastChapterNumber}`;
const isBilingualReader = entry.data.bookSlug === "founders-playbook";
---
<BaseLayout title={`${entry.data.title} | ${bookTitle}`}>
  <div class="fixed left-0 top-0 z-50 h-1 w-full bg-transparent">
    <div class="h-full bg-accent-500" data-reader-progress></div>
  </div>

  <div
    class="reader-shell grid gap-10 lg:grid-cols-[280px_minmax(0,1fr)_220px]"
    data-reader-shell
    data-prev-chapter={prev?.href}
    data-next-chapter={next?.href}
  >
    <aside class="hidden lg:block">
      <div class="sticky top-24 h-[calc(100vh-7rem)] overflow-y-auto border-r border-ink-200 pr-6 dark:border-white/10">
        <a href={`/books/${entry.data.bookSlug}/`} class="font-serif text-2xl transition hover:text-accent-600 dark:hover:text-accent-400">{bookTitle}</a>
        <p class="mt-3 font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">Contents · {progressLabel}</p>
        <nav class="mt-6 grid gap-2">
          {chapters.map((chapter, index) => (
            <a
              href={`/books/${chapter.data.bookSlug}/${getLeafSlug(chapter.id)}/`}
              class={`grid grid-cols-[34px_minmax(0,1fr)] gap-3 border-l px-3 py-2 text-sm transition ${
                chapter.id === entry.id
                  ? "border-accent-500 text-accent-600 dark:text-accent-400"
                  : "border-transparent text-ink-500 hover:border-ink-300 hover:text-ink-900 dark:text-ink-400 dark:hover:text-white"
              }`}
            >
              <span class="font-mono">{getChapterDisplayNumber(chapter, index)}</span>
              <span>{chapter.data.title}</span>
            </a>
          ))}
        </nav>
      </div>
    </aside>

    <article class={`reader-body mx-auto w-full ${isBilingualReader ? "bilingual-reader-body" : ""}`}>
      <header class="border-b border-ink-200 pb-8 dark:border-white/10">
        <div class="flex flex-wrap items-center gap-3 font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">
          <a href={`/books/${entry.data.bookSlug}/`} class="hover:text-accent-600 dark:hover:text-accent-400">{bookTitle}</a>
          <span>Chapter {currentChapterNumber}</span>
          <span>{Math.max(1, Math.round(stats.minutes))} min read</span>
        </div>
        <h1 class="mt-5 font-serif text-4xl leading-tight tracking-normal md:text-6xl">{entry.data.title}</h1>
        <p class="mt-5 max-w-3xl text-base leading-8 text-ink-600 dark:text-ink-300">{entry.data.description}</p>

        <details class="mt-8 border-y border-ink-200 py-3 lg:hidden dark:border-white/10">
          <summary class="cursor-pointer font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">Contents · {progressLabel}</summary>
          <nav class="mt-4 grid gap-2">
            {chapters.map((chapter, index) => (
              <a href={`/books/${chapter.data.bookSlug}/${getLeafSlug(chapter.id)}/`} class={`grid grid-cols-[34px_minmax(0,1fr)] gap-3 py-2 text-sm ${chapter.id === entry.id ? "text-accent-600 dark:text-accent-400" : "text-ink-600 dark:text-ink-300"}`}>
                <span class="font-mono">{getChapterDisplayNumber(chapter, index)}</span>
                <span>{chapter.data.title}</span>
              </a>
            ))}
          </nav>
        </details>
      </header>

      <div class="py-10">
        <div class="prose-shell">
          <slot />
        </div>
      </div>

      <nav class="border-t border-ink-200 pt-8 dark:border-white/10">
        <p class="mb-4 text-center font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">End of chapter · turn the page</p>
        <div class="grid gap-3 md:grid-cols-2">
          <a class={`group flex min-h-32 items-center justify-between border border-ink-200 p-5 transition dark:border-white/10 ${prev ? "hover:border-accent-500 hover:text-accent-600 dark:hover:text-accent-400" : "pointer-events-none opacity-40"}`} href={prev?.href ?? "#"}>
            <span>
              <span class="block font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">← Previous</span>
              <span class="mt-3 block font-serif text-2xl">{prev?.title ?? "已经是第一章"}</span>
            </span>
            <span class="text-3xl transition group-hover:-translate-x-1">←</span>
          </a>
          <a class={`group flex min-h-32 items-center justify-between border border-ink-200 p-5 transition dark:border-white/10 ${next ? "hover:border-accent-500 hover:text-accent-600 dark:hover:text-accent-400" : "pointer-events-none opacity-40"}`} href={next?.href ?? "#"}>
            <span>
              <span class="block font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">Next →</span>
              <span class="mt-3 block font-serif text-2xl">{next?.title ?? "已经是最后一章"}</span>
            </span>
            <span class="text-3xl transition group-hover:translate-x-1">→</span>
          </a>
        </div>
      </nav>
    </article>

    <aside class="hidden lg:block">
      <div class="sticky top-24 space-y-6 border-l border-ink-200 pl-6 text-sm dark:border-white/10">
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">Reader</p>
          <div class="mt-4">
            <BookReaderControls />
          </div>
        </div>
        <div class="border-t border-ink-200 pt-5 dark:border-white/10">
          <p class="text-ink-500 dark:text-ink-400">Keyboard</p>
          <p class="mt-2 leading-7">← previous chapter<br />→ next chapter</p>
        </div>
        <div class="border-t border-ink-200 pt-5 dark:border-white/10">
          <p class="text-ink-500 dark:text-ink-400">Tags</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {entry.data.tags.map((tag: string) => <span class="tag-chip">#{tag}</span>)}
          </div>
        </div>
      </div>
    </aside>

    <div class="fixed bottom-4 right-4 z-40 lg:hidden">
      <div class="border border-ink-200 bg-ink-50 p-2 shadow-paper dark:border-white/10 dark:bg-ink-900">
        <BookReaderControls />
      </div>
    </div>
  </div>
</BaseLayout>
