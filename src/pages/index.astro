---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../site.config";

const contactEmail = siteConfig.contactEmail;
const cvHref = siteConfig.cvHref;

const socialLinks = [
  {
    label: "GitHub",
    href: "https://github.com/methylation5mc2026-jpg",
    color: "#111111",
    icon: "github"
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/%E5%9F%8E-%E7%99%BD-302529419/",
    color: "#0a66c2",
    icon: "linkedin"
  },
  {
    label: "X",
    href: "https://x.com/cheng_bai89213",
    color: "#111111",
    icon: "x"
  },
  {
    label: "WeChat",
    href: "/assets/profile/wechat-qr.jpg",
    color: "#07c160",
    icon: "wechat"
  }
];

const newsItems = [
  {
    date: "2026 / 06",
    text: "Published this personal homepage as a public profile for projects, notes, writing, and contact information."
  },
  {
    date: "2026 / 06",
    text: "Organizing AIVC learning notes around virtual cells, proteomics, multi-omics data, model evaluation, and paper reading."
  },
  {
    date: "2026",
    text: "Team Lead, SAIS AI4S Agent CNS Challenge 2026; ranked 34th nationally and advanced to the semifinal / second round."
  },
  {
    date: "2025-2026",
    text: "Received provincial first prizes in the National Biology Olympiad / CHSBO in Shanghai for two consecutive years."
  }
];

const educationItems = [
  {
    title: "High School Student",
    meta: "Current",
    text: "Preparing for biology competitions while building foundations in computational biology and AI for Biology."
  },
  {
    title: "Biology Olympiad Training",
    meta: "Biology foundation",
    text: "Training across biochemistry, molecular biology, cell biology, genetics, physiology, ecology, and experimental reasoning."
  },
  {
    title: "Self-study in Computing",
    meta: "Ongoing",
    text: "Learning Python, data analysis, machine learning basics, bioinformatics workflows, and reproducible project documentation."
  }
];

const projectItems = [
  {
    title: "AIVC Learning Notes",
    summary: "Structured reading notes on AI Virtual Cell, proteomics, multi-omics data, and model evaluation.",
    did: "Converted long-form notes and paper readings into a chapter-based MDX reading experience with diagrams, references, and chapter navigation.",
    evidence: "Read the notes",
    href: "/books/aivc-whitepaper/",
    status: "Personal learning notes, not a formal report or research result."
  },
  {
    title: "EvoPrior-AIVC Exploratory Project",
    summary: "A reproducible single-cell perturbation-response benchmark package with conservative claim boundaries.",
    did: "Built and documented a staged pipeline around public Norman/scPerturb data, internal GEARS-compatible splits, leakage checks, model cards, and benchmark notes.",
    evidence: "GitHub repository",
    href: "https://github.com/methylation5mc2026-jpg/EvoPrior-AIVC",
    status: "Current internal result: MAE 0.430778, MSE 3.668870. This is not official GEARS, not leaderboard-comparable, and not a SOTA claim."
  },
  {
    title: "SAIS AI4S Agent CNS Challenge 2026",
    summary: "Targeted molecule R&D and synthesis planning agent built for a national AI for Science competition.",
    did: "Served as team lead; coordinated agent workflow design, literature reading, tool use, project writing, and team collaboration.",
    evidence: "Ranked 34th nationally and advanced to the semifinal / second round",
    href: "#honors",
    status: "Competition project and learning record, not a peer-reviewed research result."
  }
];

const honors = [
  "National Biology Olympiad / CHSBO 2025 Provincial First Prize, Shanghai, Rank 7.",
  "National Biology Olympiad / CHSBO 2026 Provincial First Prize, Shanghai, Rank 19.",
  "CNBO 2025 Bronze Medal.",
  "SAIS AI4S Agent CNS Challenge 2026, Rank 34 nationally, advanced to the next round, Team Lead."
];

const skillGroups = [
  {
    title: "Biology",
    items: ["Biochemistry", "Molecular biology", "Cell biology", "Immunology"]
  },
  {
    title: "Wet-lab basics",
    items: ["Pipetting", "Dilution", "Centrifugation", "PCR", "Gel electrophoresis", "Nanodrop", "Plate reader / basic spectrophotometry"]
  },
  {
    title: "Programming / Data",
    items: ["Python", "R", "pandas", "numpy", "matplotlib", "Excel"]
  },
  {
    title: "Tools",
    items: ["Linux", "Git", "conda", "GitHub", "Zotero"]
  },
  {
    title: "AI / ML",
    items: ["sklearn", "PyTorch basics", "Machine learning basics", "Deep learning basics"]
  },
  {
    title: "Bioinformatics / Omics",
    items: ["NCBI", "PDB", "PubMed", "Basic RNA/proteomics/multi-omics concepts"]
  }
];

const writingItems = [
  {
    title: "生科日报：2026.2.3",
    href: "/articles/life-science-daily-2026-02-03/",
    text: "A migrated WeChat article preserving the original text, images, and layout."
  },
  {
    title: "每天学点生物学——分子生物学冷知识",
    href: "/articles/molecular-biology-cold-knowledge/",
    text: "A public biology note written for general readers interested in molecular biology."
  }
];
---
<BaseLayout title={siteConfig.title} description={siteConfig.description}>
  <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[320px_minmax(0,1fr)]">
    <aside class="lg:sticky lg:top-24 lg:h-fit">
      <section class="paper overflow-hidden">
        <div class="border-b border-ink-200 bg-white p-6 dark:border-white/10 dark:bg-white/[0.03]">
          <div class="mx-auto w-44" data-profile-photo-root>
            <div
              class="mx-auto flex h-36 w-36 items-center justify-center overflow-hidden rounded-full border border-ink-200 bg-ink-100 font-serif text-5xl text-ink-700 dark:border-white/10 dark:bg-white/10 dark:text-ink-100"
              aria-label="Profile photo"
            >
              <img
                class="hidden h-full w-full object-cover"
                data-profile-photo-preview
                alt="Cheng Bai profile photo preview"
              />
              <span data-profile-photo-initials>CB</span>
            </div>
          </div>
          <h1 class="mt-5 text-center font-serif text-3xl tracking-normal">白城</h1>
          <p class="mt-2 text-center font-mono text-xs uppercase tracking-[0.16em] text-ink-500 dark:text-ink-400">Cheng Bai</p>
          <p class="mt-4 text-center text-sm leading-7 text-ink-600 dark:text-ink-300">
            High School Student · Biology Olympiad · AI for Biology
          </p>
          <div class="social-media mt-5" aria-label="Social profiles">
            {socialLinks.map((item) => (
              <a
                class="social-button"
                href={item.href}
                target={item.href.startsWith("#") ? undefined : "_blank"}
                rel={item.href.startsWith("#") ? undefined : "noreferrer"}
                style={`--social-accent:${item.color}`}
                aria-label={item.label}
                title={item.label}
              >
                <span class="social-fill" aria-hidden="true"></span>
                <svg viewBox="0 0 24 24" aria-hidden="true" class="social-icon-svg">
                  {item.icon === "github" && (
                    <path d="M12 2.25c-5.39 0-9.75 4.36-9.75 9.75 0 4.31 2.79 7.96 6.66 9.25.49.09.67-.21.67-.47v-1.82c-2.71.59-3.28-1.15-3.28-1.15-.44-1.13-1.08-1.43-1.08-1.43-.89-.61.07-.6.07-.6.98.07 1.5 1.01 1.5 1.01.87 1.49 2.28 1.06 2.84.81.09-.63.34-1.06.62-1.31-2.16-.25-4.43-1.08-4.43-4.82 0-1.06.38-1.94 1.01-2.62-.1-.25-.44-1.24.1-2.58 0 0 .82-.26 2.68 1 .78-.22 1.61-.33 2.44-.33.83 0 1.66.11 2.44.33 1.86-1.26 2.68-1 2.68-1 .54 1.34.2 2.33.1 2.58.63.68 1.01 1.55 1.01 2.62 0 3.75-2.28 4.57-4.45 4.81.35.3.66.9.66 1.82v2.7c0 .26.18.57.68.47A9.75 9.75 0 0 0 21.75 12c0-5.39-4.36-9.75-9.75-9.75Z" />
                  )}
                  {item.icon === "linkedin" && (
                    <path d="M5.37 8.84H2.56v9.03h2.81V8.84ZM3.97 4.37c-.9 0-1.62.73-1.62 1.62s.72 1.62 1.62 1.62c.89 0 1.62-.73 1.62-1.62S4.86 4.37 3.97 4.37Zm12.22 4.25c-1.38 0-2.31.76-2.69 1.48h-.04V8.84h-2.69v9.03h2.81v-4.47c0-1.18.22-2.32 1.68-2.32 1.44 0 1.46 1.35 1.46 2.39v4.4h2.81v-4.96c0-2.43-.52-4.29-3.34-4.29ZM9.11 8.84H6.31v9.03h2.8V8.84Z" />
                  )}
                  {item.icon === "x" && (
                    <path d="M14.28 10.16 22.03 1.5h-1.84l-6.73 7.52L8.09 1.5H1.9l8.13 11.39-8.13 9.09h1.84l7.1-7.94 5.67 7.94h6.19l-8.42-11.82Zm-2.51 2.81-.82-1.13L4.39 2.83h2.82l5.29 7.26.82 1.13 6.88 9.45h-2.82l-5.61-7.7Z" />
                  )}
                  {item.icon === "wechat" && (
                    <>
                      <path d="M9.25 5.05c-4.02 0-7.28 2.68-7.28 5.98 0 1.87 1.05 3.54 2.69 4.63l-.6 2.12 2.47-1.24c.84.29 1.75.45 2.72.45.3 0 .6-.02.89-.05a5.74 5.74 0 0 1-.35-1.97c0-3.01 2.73-5.45 6.13-5.45.18 0 .37.01.55.02-.82-2.58-3.71-4.49-7.22-4.49Zm-2.49 4.9a.9.9 0 1 1 0-1.8.9.9 0 0 1 0 1.8Zm5.01 0a.9.9 0 1 1 0-1.8.9.9 0 0 1 0 1.8Z" />
                      <path d="M16.05 10.63c-2.88 0-5.21 1.96-5.21 4.37s2.33 4.37 5.21 4.37c.7 0 1.37-.12 1.98-.33l1.9.95-.46-1.65c1.09-.81 1.78-2 1.78-3.34 0-2.41-2.33-4.37-5.2-4.37Zm-1.76 3.25a.7.7 0 1 1 0-1.4.7.7 0 0 1 0 1.4Zm3.53 0a.7.7 0 1 1 0-1.4.7.7 0 0 1 0 1.4Z" />
                    </>
                  )}
                </svg>
              </a>
            ))}
          </div>
        </div>

        <div class="space-y-4 p-6 text-sm">
          <div>
            <p class="font-mono text-xs uppercase tracking-[0.16em] text-ink-500 dark:text-ink-400">Contact</p>
            <div class="mt-3 grid gap-2 text-ink-600 dark:text-ink-300">
              <a class="hover:text-accent-600 dark:hover:text-accent-400" href={`mailto:${contactEmail}`}>{contactEmail}</a>
              <a class="hover:text-accent-600 dark:hover:text-accent-400" href="https://github.com/methylation5mc2026-jpg" target="_blank" rel="noreferrer">GitHub overview</a>
              <a class="hover:text-accent-600 dark:hover:text-accent-400" href={cvHref} download>Download CV</a>
              <a class="hover:text-accent-600 dark:hover:text-accent-400" href={siteConfig.url}>Personal website</a>
            </div>
          </div>
          <div class="border-t border-ink-200 pt-4 dark:border-white/10">
            <p class="font-mono text-xs uppercase tracking-[0.16em] text-ink-500 dark:text-ink-400">Current Focus</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {siteConfig.focus.map((item) => <span class="focus-pill">{item}</span>)}
            </div>
          </div>
        </div>
      </section>
    </aside>

    <div class="space-y-12">
      <section id="about" class="section-rule scroll-mt-24 pt-0">
        <p class="eyebrow">About</p>
        <div class="mt-4 space-y-5 text-base leading-8 text-ink-700 dark:text-ink-200">
          <p>
            I am a high school student in Shanghai with sustained training in the biology olympiad system. My current academic interest is AI for Biology, especially computational biology, single-cell and multi-omics data, proteomics, and AI Virtual Cell.
          </p>
          <p>
            This website collects a small number of materials that I want teachers, mentors, and peers to inspect directly: project records, reading notes, competition experience, and original writing.
          </p>
          <p>
            I am still at an early stage. I try to keep claims narrow, record limitations clearly, and treat each project as a way to build better scientific judgment.
          </p>
        </div>
      </section>

      <section id="news" class="section-rule scroll-mt-24">
        <p class="eyebrow">News</p>
        <h2 class="mt-2 font-serif text-4xl tracking-normal">Recent Updates</h2>
        <div class="mt-6 grid gap-4">
          {newsItems.map((item) => (
            <article class="grid gap-3 border-b border-ink-200 pb-4 dark:border-white/10 md:grid-cols-[120px_minmax(0,1fr)]">
              <p class="font-mono text-sm text-ink-500 dark:text-ink-400">{item.date}</p>
              <p class="leading-7 text-ink-700 dark:text-ink-200">{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="education" class="section-rule scroll-mt-24">
        <p class="eyebrow">Education</p>
        <h2 class="mt-2 font-serif text-4xl tracking-normal">Education and Training</h2>
        <div class="mt-6 grid gap-4">
          {educationItems.map((item) => (
            <article class="grid gap-4 border-b border-ink-200 pb-5 dark:border-white/10 md:grid-cols-[120px_minmax(0,1fr)]">
              <p class="font-mono text-sm text-ink-500 dark:text-ink-400">{item.meta}</p>
              <div>
                <h3 class="font-serif text-2xl tracking-normal">{item.title}</h3>
                <p class="mt-2 text-sm leading-7 text-ink-600 dark:text-ink-300">{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="projects" class="section-rule scroll-mt-24">
        <p class="eyebrow">Selected Projects & Notes</p>
        <h2 class="mt-2 font-serif text-4xl tracking-normal">Work I Want Visitors to Inspect First</h2>
        <div class="mt-6 grid gap-5">
          {projectItems.map((project) => (
            <article class="paper p-5">
              <div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_240px]">
                <div>
                  <h3 class="font-serif text-3xl tracking-normal">{project.title}</h3>
                  <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">{project.summary}</p>
                  <div class="mt-4 grid gap-3 text-sm leading-7">
                    <p><span class="font-medium text-ink-900 dark:text-white">What I did:</span> {project.did}</p>
                    <p><span class="font-medium text-ink-900 dark:text-white">Status / limitation:</span> {project.status}</p>
                  </div>
                </div>
                <div class="flex items-start lg:justify-end">
                  <a class="asset-button" href={project.href} target={project.href.startsWith("http") ? "_blank" : undefined} rel={project.href.startsWith("http") ? "noreferrer" : undefined}>
                    {project.evidence}
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="honors" class="section-rule scroll-mt-24">
        <p class="eyebrow">Honors</p>
        <h2 class="mt-2 font-serif text-4xl tracking-normal">Selected Records</h2>
        <ul class="mt-6 space-y-4 text-sm leading-7 text-ink-700 dark:text-ink-200">
          {honors.map((item) => (
            <li class="border-b border-ink-200 pb-4 dark:border-white/10">{item}</li>
          ))}
        </ul>
      </section>

      <section id="skills" class="section-rule scroll-mt-24">
        <p class="eyebrow">Technical Skills</p>
        <h2 class="mt-2 font-serif text-4xl tracking-normal">Current Foundation</h2>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-ink-600 dark:text-ink-300">
          These are areas I am familiar with or currently learning. They are listed as foundations, not as expert-level claims.
        </p>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {skillGroups.map((group) => (
            <section class="border-b border-ink-200 pb-5 dark:border-white/10">
              <h3 class="font-serif text-2xl tracking-normal">{group.title}</h3>
              <div class="mt-3 flex flex-wrap gap-2">
                {group.items.map((item) => <span class="focus-pill">{item}</span>)}
              </div>
            </section>
          ))}
        </div>
      </section>

      <section id="writing" class="section-rule scroll-mt-24">
        <p class="eyebrow">Writing</p>
        <h2 class="mt-2 font-serif text-4xl tracking-normal">Original Articles</h2>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-ink-600 dark:text-ink-300">
          The writing archive currently preserves four migrated WeChat articles. The homepage highlights only a small subset.
        </p>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          {writingItems.map((item) => (
            <a class="route-card group" href={item.href}>
              <h3 class="font-serif text-2xl tracking-normal">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">{item.text}</p>
              <span class="mt-4 inline-block font-mono text-xs uppercase tracking-[0.18em] text-accent-600 transition group-hover:translate-x-1 dark:text-accent-400">Open</span>
            </a>
          ))}
        </div>
        <a class="mt-5 inline-block text-sm text-accent-600 hover:text-accent-500 dark:text-accent-400" href="/articles/">View full writing archive</a>
      </section>

      <section id="notes" class="section-rule scroll-mt-24">
        <p class="eyebrow">Notes</p>
        <h2 class="mt-2 font-serif text-4xl tracking-normal">Long-form Notes</h2>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <a class="route-card group" href="/books/aivc-whitepaper/">
            <h3 class="font-serif text-2xl tracking-normal">Notes on AI Virtual Cell</h3>
            <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">
              Chapter-based learning notes on AI Virtual Cell, single-cell data, proteomics, and model evaluation.
            </p>
            <span class="mt-4 inline-block font-mono text-xs uppercase tracking-[0.18em] text-accent-600 transition group-hover:translate-x-1 dark:text-accent-400">Read notes</span>
          </a>
          <a class="route-card group" href="/knowledge-map/">
            <h3 class="font-serif text-2xl tracking-normal">Knowledge Map</h3>
            <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">
              A compact map of the main learning directions and available notes on this site.
            </p>
            <span class="mt-4 inline-block font-mono text-xs uppercase tracking-[0.18em] text-accent-600 transition group-hover:translate-x-1 dark:text-accent-400">Open map</span>
          </a>
        </div>
      </section>

      <section id="contact" class="section-rule scroll-mt-24">
        <p class="eyebrow">Contact</p>
        <h2 class="mt-2 font-serif text-4xl tracking-normal">Academic Contact</h2>
        <div class="mt-5 grid gap-4 text-sm leading-7 text-ink-600 dark:text-ink-300 md:grid-cols-3">
          <a class="border-y border-ink-200 py-5 transition hover:border-accent-500 hover:text-accent-600 dark:border-white/10 dark:hover:text-accent-400" href={`mailto:${contactEmail}`}>
            <span class="block font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">Email</span>
            <span class="mt-2 block">{contactEmail}</span>
          </a>
          <a class="border-y border-ink-200 py-5 transition hover:border-accent-500 hover:text-accent-600 dark:border-white/10 dark:hover:text-accent-400" href="https://github.com/methylation5mc2026-jpg" target="_blank" rel="noreferrer">
            <span class="block font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">GitHub</span>
            <span class="mt-2 block">methylation5mc2026-jpg</span>
          </a>
          <a class="border-y border-ink-200 py-5 transition hover:border-accent-500 hover:text-accent-600 dark:border-white/10 dark:hover:text-accent-400" href={cvHref} download>
            <span class="block font-mono text-xs uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">CV</span>
            <span class="mt-2 block">Download CV</span>
          </a>
        </div>
      </section>
    </div>
  </div>

  <script>
    const root = document.querySelector("[data-profile-photo-root]");

    if (root) {
      const storageKey = "chengbai.profilePhoto";
      const preview = root.querySelector<HTMLImageElement>("[data-profile-photo-preview]");
      const initials = root.querySelector<HTMLElement>("[data-profile-photo-initials]");

      try {
        const storedPhoto = localStorage.getItem(storageKey);
        if (storedPhoto && preview && initials) {
          preview.src = storedPhoto;
          preview.classList.remove("hidden");
          initials.classList.add("hidden");
        }
      } catch {
        // Keep the default initials if browser storage is unavailable.
      }
    }
  </script>

  <style>
    .social-media {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.72rem;
    }

    .social-button {
      position: relative;
      display: inline-flex;
      width: 2.8rem;
      height: 2.8rem;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      border: 1px solid rgba(214, 208, 196, 0.92);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.82);
      color: var(--social-accent);
      box-shadow: 0 8px 22px rgba(36, 31, 24, 0.1);
      transition:
        transform 260ms cubic-bezier(0.2, 0.8, 0.2, 1),
        border-color 260ms ease,
        box-shadow 260ms ease,
        color 260ms ease;
    }

    .social-fill {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 0;
      height: 0;
      border-radius: 999px;
      background: var(--social-accent);
      transform: translate(-50%, -50%);
      transition:
        width 280ms ease,
        height 280ms ease;
    }

    .social-icon-svg {
      position: relative;
      z-index: 1;
      width: 1.28rem;
      height: 1.28rem;
      fill: currentColor;
      transition: transform 260ms ease;
    }

    .social-button:hover,
    .social-button:focus-visible {
      border-color: color-mix(in srgb, var(--social-accent) 58%, transparent);
      color: #ffffff;
      transform: translateY(-4px);
      box-shadow: 0 16px 30px rgba(36, 31, 24, 0.18);
    }

    .social-button:hover .social-fill,
    .social-button:focus-visible .social-fill {
      width: 100%;
      height: 100%;
    }

    .social-button:hover .social-icon-svg,
    .social-button:focus-visible .social-icon-svg {
      transform: scale(1.08);
    }

    .social-button:focus-visible {
      outline: 3px solid color-mix(in srgb, var(--social-accent) 42%, transparent);
      outline-offset: 3px;
    }

    :global(.dark) .social-button {
      border-color: rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.06);
      box-shadow: none;
    }

    @media (prefers-reduced-motion: reduce) {
      .social-button,
      .social-fill,
      .social-icon-svg {
        transition: none;
      }
    }
  </style>
</BaseLayout>
