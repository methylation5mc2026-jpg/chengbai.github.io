---
import BaseLayout from "../layouts/BaseLayout.astro";

const topics = [
  {
    title: "AI for Biology",
    links: [
      { title: "AIVC Learning Notes", href: "/books/aivc-whitepaper/" },
      { title: "EvoPrior-AIVC", href: "https://github.com/methylation5mc2026-jpg/EvoPrior-AIVC" }
    ]
  },
  {
    title: "Bioinformatics",
    links: [
      { title: "AIVC Learning Notes", href: "/books/aivc-whitepaper/" }
    ]
  },
  {
    title: "Biology Olympiad",
    links: [
      { title: "生科日报：2026.2.3", href: "/articles/life-science-daily-2026-02-03/" },
      { title: "每天学点生物学——分子生物学冷知识", href: "/articles/molecular-biology-cold-knowledge/" }
    ]
  }
];
---
<BaseLayout title="Topics | Cheng Bai" description="Topics.">
  <div class="space-y-10">
    <section class="border-b border-ink-200 pb-10 dark:border-white/10">
      <h1 class="font-serif text-5xl leading-tight tracking-normal md:text-7xl">Topics</h1>
    </section>

    <section class="grid gap-6">
      {topics.map((topic) => (
        <article class="grid gap-4 border-b border-ink-200 pb-6 dark:border-white/10 md:grid-cols-[220px_minmax(0,1fr)]">
          <h2 class="font-serif text-3xl tracking-normal">{topic.title}</h2>
          <div class="grid gap-2 text-sm leading-7">
            {topic.links.map((item) => (
              <a class="text-ink-700 transition hover:text-accent-600 dark:text-ink-200 dark:hover:text-accent-400" href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
                {item.title}
              </a>
            ))}
          </div>
        </article>
      ))}
    </section>
  </div>
</BaseLayout>
